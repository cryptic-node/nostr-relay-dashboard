# Copy to `.env` next to the compose file you're using. Real `.env` stays out
# of git (see .dockerignore and .gitignore).
#
# Required for the production compose (docker-compose.prod.yml). Optional for
# the dev and generic compose files, but strongly recommended on anything
# reachable beyond localhost.
#
# Generate with: openssl rand -hex 32
NRD_ADMIN_TOKEN=

# Optional overrides — leave commented to use compose-file defaults.
# RUST_LOG=nostr_relay_dashboard=debug
